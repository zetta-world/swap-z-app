# ─────────────────────────────────────────────────────────────────────────
# Z-SWAP — environment variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development, OR set these in your
# Vercel project (Settings → Environment Variables).

# ── REQUIRED for ZION AI (server-side, never exposed to the client) ───
# Get a key at https://platform.claude.com → Settings → API Keys.
# Recommended: scope to the z-swap workspace + set a monthly budget alert.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL: WalletConnect v2 support ────────────────────────────────
# Without this, only injected wallets (MetaMask, Rabby, Brave, OKX, etc.)
# and Coinbase Wallet (popup fallback) are offered. Set it to also enable
# WalletConnect QR + mobile wallet flow.
# Get a free projectId at https://cloud.reown.com (formerly cloud.walletconnect.com).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# All public-data integrations (GoPlus, Honeypot.is, GeckoTerminal,
# DexScreener) require NO keys — they are public APIs with generous tiers.
