# ─────────────────────────────────────────────────────────────────────────
# Z-SWAP — environment variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development, OR set these in your
# Vercel project (Settings → Environment Variables).

# ── REQUIRED for ZION AI (server-side, never exposed to the client) ───
# Get a key at https://platform.claude.com → Settings → API Keys.
# Recommended: scope to the z-swap workspace + set a monthly budget alert.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── REQUIRED for real swap execution (0x Swap API v2 + Permit2) ──────
# Server-side only — never exposed to the client.
# Get a free key at https://0x.org → dashboard → create API key.
# Free tier: 100 req/s, 200K req/month — enough for thousands of users.
ZEROX_API_KEY=

# ── OPTIONAL: WalletConnect v2 support ────────────────────────────────
# Without this, only injected wallets (MetaMask, Rabby, Brave, OKX, etc.)
# and Coinbase Wallet (popup fallback) are offered. Set it to also enable
# WalletConnect QR + mobile wallet flow.
# Get a free projectId at https://cloud.reown.com (formerly cloud.walletconnect.com).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# All public-data integrations (GoPlus, Honeypot.is, GeckoTerminal,
# DexScreener) require NO keys — they are public APIs with generous tiers.

# ─────────────────────────────────────────────────────────────────────────
# FASE 5.2 + 5.3 — wallet auth & tier gating (all OPTIONAL until launch)
# ─────────────────────────────────────────────────────────────────────────
# The app degrades gracefully when these are unset: auth endpoints return a
# clear 503, and every wallet resolves to the "free" tier. Nothing crashes.

# ── Supabase (server-side only — service-role key NEVER ships to the client)
# Create a project at https://supabase.com, run supabase/migrations/0001_auth.sql
# in the SQL Editor, then copy these from Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── JWT signing secret for the session cookie (HMAC SHA-256) ─────────────
# Generate one with: openssl rand -base64 48
AUTH_JWT_SECRET=

# ── Helius RPC (Solana mainnet) — used to read NFT ownership for tier ─────
# Get a free key at https://helius.dev. MUST be a mainnet URL (never devnet).
HELIUS_RPC_URL=

# ── NFT membership collection address (set once the 5.4 mint deploys) ─────
# Leave blank until then — tier checks fall back to "free" / cache-only.
ZSWAP_COLLECTION_ADDRESS=

# ── Tier-gate master switch ──────────────────────────────────────────────
# "false" (default): all infrastructure live but gates are DORMANT — every
#   feature stays open, ZION never returns 402. Flip to "true" only after the
#   NFT mint is live so paying members actually have a way to unlock.
TIER_GATES_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────
# BACKGROUND AUTOPILOT (server-side cron execution) — all OPTIONAL
# ─────────────────────────────────────────────────────────────────────────
# When unset, background mode is disabled and the UI says so; the in-browser
# autopilot keeps working unchanged. Requires Supabase (above) + these two.

# ── AES-256 key that encrypts CEX credentials at rest in Supabase ─────────
# 32 bytes. Generate with: openssl rand -base64 32   (or 64 hex chars).
# NEVER commit a real value. Rotating it invalidates all armed sessions.
AUTOPILOT_ENC_KEY=

# ── Shared secret the GitHub Actions cron uses to call /api/autopilot/cron ─
# Generate with: openssl rand -base64 32
# Set the SAME value as a GitHub repo secret named CRON_SECRET, plus a
# secret AUTOPILOT_CRON_URL = https://<your-domain>/api/autopilot/cron
CRON_SECRET=
